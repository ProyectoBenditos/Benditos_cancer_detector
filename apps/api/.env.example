# Variables de entorno del backend FastAPI (OncaScan API).
# Copiar este archivo a .env y rellenar los valores reales.

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_BUCKET_NAME=dicom-files

# --- Hugging Face inference (OncaScan AI Space) ---
# URL base del Space que expone /predict. Cambiar si el Space se mueve.
HF_API_BASE_URL=https://luisdam-oncoscan-ai.hf.space
# Timeout (segundos) para la peticion al modelo. Subir si el Space hace cold-start.
HF_PREDICT_TIMEOUT=120
